<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorHeaderBg"
            android:paddingTop="36dp"
            android:paddingBottom="28dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x1F6A8;"
                android:textSize="52sp" />

            <TextView
                android:id="@+id/home_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="FallAlert"
                android:textStyle="bold"
                android:textSize="34sp"
                android:textColor="@color/colorHeaderText"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/home_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Monitoreo de alertas por Bluetooth"
                android:textSize="14sp"
                android:textColor="@color/colorHeaderSubtext"
                android:gravity="center" />
        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Buttons -->
            <Button
                android:id="@+id/btn_start_listening"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/colorHeaderText"
                android:text="Iniciar escucha en segundo plano"
                android:textSize="15sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_open_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/colorTextSecondary"
                android:textColor="@color/colorHeaderText"
                android:text="Configuracion"
                android:textSize="15sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <!-- Hint card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:background="@color/colorHintBg"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4A1; Primeros pasos"
                    android:textStyle="bold"
                    android:textColor="@color/colorHintTitle"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/home_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Selecciona y empareja el dispositivo en Configuracion antes de iniciar la escucha."
                    android:textSize="13sp"
                    android:textColor="@color/colorHintText"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
