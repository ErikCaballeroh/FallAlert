<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/home_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FallAlert"
        android:textStyle="bold"
        android:textSize="28sp"
        android:textColor="@color/colorPrimaryDark" />

    <TextView
        android:id="@+id/home_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Monitoreo de alertas por Bluetooth para activar notificaciones remotas"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/home_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textSize="14sp"
        android:textColor="#444444" />

    <Button
        android:id="@+id/btn_start_listening"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Iniciar escucha en segundo plano" />

    <Button
        android:id="@+id/btn_open_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Configuracion" />

    <TextView
        android:id="@+id/home_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Primero selecciona y empareja el dispositivo en Configuracion.\nLa app no fuerza conexion Bluetooth al abrirse."
        android:textSize="13sp"
        android:textColor="#666666" />

</LinearLayout>
